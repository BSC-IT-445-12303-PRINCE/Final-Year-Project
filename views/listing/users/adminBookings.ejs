<% layout("./listing/layouts/boilerplate") %>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-calendar-check me-2 text-primary"></i>All Bookings</h2>
        <div>
            <a href="/admin/dashboard" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">Pending</h5>
                    <h3><%= bookings.filter(b => b.status === 'pending').length %></h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Confirmed</h5>
                    <h3><%= bookings.filter(b => b.status === 'confirmed').length %></h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">Completed</h5>
                    <h3><%= bookings.filter(b => b.status === 'completed').length %></h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h5 class="card-title">Cancelled</h5>
                    <h3><%= bookings.filter(b => b.status === 'cancelled').length %></h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Bookings Table -->
    <div class="card shadow">
        <div class="card-body">
            <% if (bookings.length === 0) { %>
                <div class="text-center py-5">
                    <i class="fas fa-calendar-times fa-4x text-muted mb-3"></i>
                    <h4 class="text-muted">No bookings yet</h4>
                </div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Listing</th>
                                <th>User</th>
                                <th>Dates</th>
                                <th>Guests</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Payment</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% bookings.forEach(function(booking) { %>
                                <tr>
                                    <td><code><%= booking._id.toString().slice(-6) %></code></td>
                                    <td>
                                        <% if (booking.listing) { %>
                                            <%= booking.listing.title %>
                                            <br><small class="text-muted"><%= booking.listing.location %></small>
                                        <% } else { %>
                                            <span class="text-muted">Deleted Listing</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (booking.user) { %>
                                            <%= booking.user.username %>
                                            <br><small class="text-muted"><%= booking.user.email %></small>
                                        <% } else { %>
                                            <span class="text-muted">Unknown</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <small>
                                            <%= new Date(booking.checkIn).toLocaleDateString() %>
                                            <br>to<br>
                                            <%= new Date(booking.checkOut).toLocaleDateString() %>
                                        </small>
                                    </td>
                                    <td>
                                        <%= booking.guests.adults + booking.guests.children %>
                                        <small class="text-muted">(<%= booking.guests.adults %>A, <%= booking.guests.children %>C)</small>
                                    </td>
                                    <td>
                                        <strong>₹<%= booking.totalPrice.toLocaleString() %></strong>
                                        <br><small class="text-muted">₹<%= booking.pricePerNight %> x <%= booking.totalNights %> nights</small>
                                    </td>
                                    <td>
                                        <span class="badge 
                                            <%= booking.status === 'confirmed' ? 'bg-success' : '' %>
                                            <%= booking.status === 'pending' ? 'bg-warning' : '' %>
                                            <%= booking.status === 'cancelled' ? 'bg-danger' : '' %>
                                            <%= booking.status === 'completed' ? 'bg-info' : '' %>">
                                            <%= booking.status %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge 
                                            <%= booking.payment.status === 'paid' ? 'bg-success' : '' %>
                                            <%= booking.payment.status === 'pending' ? 'bg-warning' : '' %>
                                            <%= booking.payment.status === 'failed' ? 'bg-danger' : '' %>
                                            <%= booking.payment.status === 'refunded' ? 'bg-secondary' : '' %>">
                                            <%= booking.payment.status %>
                                        </span>
                                    </td>
                                    <td>
                                        <a href="/admin/bookings/<%= booking._id %>" class="btn btn-sm btn-primary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</div>
