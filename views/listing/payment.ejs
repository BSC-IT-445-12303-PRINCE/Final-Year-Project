<% layout("./listing/layouts/boilerplate") %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="fas fa-lock me-2"></i>Secure Payment</h4>
                </div>
                <div class="card-body p-4">
                    <!-- Booking Summary -->
                    <div class="bg-light p-3 rounded mb-4">
                        <h6 class="mb-2">Booking Summary</h6>
                        <div class="d-flex justify-content-between mb-1">
                            <span><%= booking.listing.title %></span>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span><%= new Date(booking.checkIn).toDateString() %> - <%= new Date(booking.checkOut).toDateString() %></span>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span><%= booking.guests.adults %> Adults, <%= booking.guests.children %> Children</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between fw-bold text-success">
                            <span>Total Amount:</span>
                            <span>₹<%= booking.totalPrice.toLocaleString() %></span>
                        </div>
                    </div>

                    <!-- Payment Status -->
                    <div class="alert alert-info mb-4">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Payment Status:</strong> <%= booking.payment.status.toUpperCase() %>
                    </div>

                    <!-- Demo Payment Form -->
                    <form action="/bookings/<%= booking._id %>/payment/process" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Card Number</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-credit-card"></i></span>
                                <input type="text" class="form-control" placeholder="4242 4242 4242 4242" maxlength="19">
                            </div>
                            <small class="text-muted">Demo: Use any 16-digit number</small>
                        </div>

                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label fw-bold">Expiry Date</label>
                                <input type="text" class="form-control" placeholder="MM/YY" maxlength="5">
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold">CVV</label>
                                <input type="text" class="form-control" placeholder="123" maxlength="3">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Cardholder Name</label>
                            <input type="text" class="form-control" placeholder="Name on card">
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="fas fa-lock me-2"></i>Pay ₹<%= booking.totalPrice.toLocaleString() %>
                            </button>
                        </div>

                        <div class="text-center mt-3">
                            <small class="text-muted">
                                <i class="fas fa-shield-alt me-1"></i>Secure SSL Encrypted Transaction
                            </small>
                        </div>
                    </form>

                    <!-- Back to Bookings -->
                    <hr>
                    <div class="text-center">
                        <a href="/bookings/my" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Back to My Bookings
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
